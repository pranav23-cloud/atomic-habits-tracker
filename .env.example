## Firebase (client)
## Note: Firebase web config values are not "secret" but keep them in env for convenience.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

## YouTube Data API v3
## IMPORTANT: This key will be visible in the browser in a pure-Vite setup.
## Restrict it in Google Cloud Console (HTTP referrers) to your domain(s).
VITE_YOUTUBE_API_KEY=
